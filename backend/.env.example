# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/deukhuri_erp?schema=public"

# Security & Tokens
CORS_ORIGIN=http://localhost:5173
JWT_SECRET="super-secret-key-change-this-in-production"
JWT_EXPIRATION="7d"
JWT_ACCESS_SECRET="super-secret-access-key-change-this-in-production"
JWT_REFRESH_SECRET="super-secret-refresh-key-change-this-in-production-refresh"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"

# Logging
LOG_LEVEL=info

# Cloudinary Storage
CLOUDINARY_CLOUD_NAME=placeholder
CLOUDINARY_API_KEY=placeholder
CLOUDINARY_API_SECRET=placeholder

# SMTP Mail Server Configuration
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=placeholder
SMTP_PASS=placeholder
SMTP_FROM="Deukhuri Digital Campus <noreply@deukhuri.edu>"
